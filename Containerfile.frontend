FROM node:20-alpine

WORKDIR /app

COPY user-portal/package*.json ./
RUN npm ci

COPY user-portal/ ./

ARG VITE_API_BASE_URL
ARG VITE_SITE_KEY

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_SITE_KEY=$VITE_SITE_KEY

RUN npm run build

EXPOSE 5173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5173"]